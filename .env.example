# Copy this file to .env before starting the stack.
# Keep the real RTSP URL only in .env because it contains camera credentials.
# ใช้ได้กับกล้อง RTSP ทุกยี่ห้อ (Tapo, Hikvision, Dahua, Reolink, ฯลฯ)
# Example:
#   Tapo:      rtsp://username:password@192.168.1.50/stream1
#   Hikvision: rtsp://admin:password@192.168.1.50:554/Streaming/Channels/101
#   Dahua:     rtsp://admin:password@192.168.1.50:554/cam/realmonitor?channel=1&subtype=0

# ===== Multi-Camera Configuration =====
# Add CAMERA_<NAME>_RTSP_URL for each camera. Leave blank or remove to disable.
# The system auto-generates Frigate config from these variables on startup.
CAMERA_FRONT_RTSP_URL=rtsp://username:password@192.168.1.50/stream1
CAMERA_BACK_RTSP_URL=rtsp://thekiller2:T077221144t@10.95.10.248/stream1
CAMERA_PARKING_RTSP_URL=
CAMERA_GATE_RTSP_URL=

# Optional zone definitions per camera (format: zone_name:x1,y1,x2,y2,x3,y3,x4,y4)
# Multiple zones separated by semicolons: zone1:coords;zone2:coords
CAMERA_FRONT_ZONES=front_door:0.05,0.95,0.38,0.95,0.38,0.40,0.05,0.40
CAMERA_BACK_ZONES=
CAMERA_PARKING_ZONES=
CAMERA_GATE_ZONES=

# Detection resolution and FPS (shared across all cameras)
FRIGATE_DETECT_WIDTH=1280
FRIGATE_DETECT_HEIGHT=720
FRIGATE_DETECT_FPS=5

FRIGATE_TIMEZONE=Asia/Bangkok

# Frigate authentication (change these!)
FRIGATE_DEFAULT_USER=admin
FRIGATE_DEFAULT_PASSWORD=SquareGuardian2026

# SquareGuardian detector settings
POLL_INTERVAL_SEC=2
TRACKED_ITEMS=person,car,motorcycle,bus,backpack,suitcase,handbag

# Snapshot burst: capture multiple snapshots and pick the sharpest one
SNAPSHOT_BURST_COUNT=3
SNAPSHOT_BURST_INTERVAL_MS=500

# Alert cooldown: seconds to suppress duplicate face-id alerts per camera (0=disabled)
ALERT_COOLDOWN_SEC=300

# Storage limits (circular buffer: delete oldest when full)
MAX_STORAGE_GB=256
BUFFER_GB=10
SAVE_INTERVAL_SEC=30

# Face recognition service (starts automatically with docker compose up)
# Set to empty to disable face recognition even when the container is running.
FACE_SERVICE_URL=http://face-service:8082
