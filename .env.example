# Copy this file to .env before starting the stack.
# Keep the real RTSP URL only in .env because it contains camera credentials.
# Example for TP-Link Tapo main stream:
# FRIGATE_TAPO_RTSP_URL=rtsp://username:password@192.168.1.50/stream1

FRIGATE_TAPO_RTSP_URL=rtsp://username:password@192.168.1.50/stream1
FRIGATE_TIMEZONE=Asia/Bangkok

# Frigate authentication (change these!)
FRIGATE_DEFAULT_USER=admin
FRIGATE_DEFAULT_PASSWORD=SpaceGuardian2026

# SpaceGuardian detector settings
POLL_INTERVAL_SEC=5
TRACKED_ITEMS=person,car,motorcycle,bus,backpack,suitcase,handbag

# Storage limits (circular buffer: delete oldest when full)
MAX_STORAGE_GB=256
BUFFER_GB=10
SAVE_INTERVAL_SEC=30
