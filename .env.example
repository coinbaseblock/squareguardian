# Copy this file to .env before starting the stack.
# Keep the real RTSP URL only in .env because it contains camera credentials.
# ใช้ได้กับกล้อง RTSP ทุกยี่ห้อ (Tapo, Hikvision, Dahua, Reolink, ฯลฯ)
# Example:
#   Tapo:      rtsp://username:password@192.168.1.50/stream1
#   Hikvision: rtsp://admin:password@192.168.1.50:554/Streaming/Channels/101
#   Dahua:     rtsp://admin:password@192.168.1.50:554/cam/realmonitor?channel=1&subtype=0

# ===== Multi-Camera Configuration =====
# Add CAMERA_<NAME>_RTSP_URL for each camera. Leave blank or remove to disable.
# The system auto-discovers all CAMERA_*_RTSP_URL vars on startup — no need
# to edit docker-compose.yml when adding or removing cameras.
CAMERA_FRONT_RTSP_URL=rtsp://username:password@192.168.1.50/stream1
CAMERA_BACK_RTSP_URL=
CAMERA_PARKING_RTSP_URL=
CAMERA_GATE_RTSP_URL=

# ===== Per-Camera Substream (สำคัญ — ประหยัด CPU 40-60%) =====
# ใช้ substream (720p) สำหรับ motion detection → เบากว่ามาก
# main stream (2K/4K) จะถูกใช้สำหรับ snapshot/face recognition → คุณภาพเต็ม
# For high-res cameras (2K/4K), use a substream for detection (saves CPU)
# and the main stream for snapshots (full quality for face recognition).
# Tapo ทุกรุ่นรองรับ /stream2 เป็น substream
# Tapo C260 example (2K main, 720p sub):
#   CAMERA_FRONT_SUBSTREAM_URL=rtsp://username:password@192.168.1.50/stream2
# Hikvision example (main ch101, sub ch102):
#   CAMERA_FRONT_SUBSTREAM_URL=rtsp://admin:password@192.168.1.50:554/Streaming/Channels/102
CAMERA_FRONT_SUBSTREAM_URL=
CAMERA_BACK_SUBSTREAM_URL=
CAMERA_PARKING_SUBSTREAM_URL=
CAMERA_GATE_SUBSTREAM_URL=

# ===== Per-Camera Detection Resolution (optional) =====
# Override detection resolution per camera. Higher = better detection, more CPU.
# Leave blank to use global defaults (FRIGATE_DETECT_WIDTH/HEIGHT).
# เมื่อใช้ substream แล้ว ค่า detect resolution นี้จะใช้กับ substream (720p)
# ส่วนใหญ่ปล่อยว่างได้ ระบบจะใช้ค่า global default
# For 4K cameras: 1920x1080 recommended
# For 2K cameras: 1280x720 or 1920x1080
# For 1080p cameras: 1280x720 is fine
CAMERA_FRONT_DETECT_WIDTH=
CAMERA_FRONT_DETECT_HEIGHT=
CAMERA_BACK_DETECT_WIDTH=
CAMERA_BACK_DETECT_HEIGHT=
CAMERA_PARKING_DETECT_WIDTH=
CAMERA_PARKING_DETECT_HEIGHT=
CAMERA_GATE_DETECT_WIDTH=
CAMERA_GATE_DETECT_HEIGHT=

# Optional zone definitions per camera (format: zone_name:x1,y1,x2,y2,x3,y3,x4,y4)
# Multiple zones separated by semicolons: zone1:coords;zone2:coords
CAMERA_FRONT_ZONES=
CAMERA_BACK_ZONES=
CAMERA_PARKING_ZONES=
CAMERA_GATE_ZONES=

# Detection resolution and FPS (global default, shared across all cameras)
# Per-camera overrides above take priority over these.
# For better person detection accuracy (especially at frame edges), use 1920x1080.
# Use 1280x720 only if CPU is constrained.
# snapshot สำหรับ face recognition จะดึงจาก main stream (2K) อยู่แล้ว
FRIGATE_DETECT_WIDTH=1920
FRIGATE_DETECT_HEIGHT=1080
FRIGATE_DETECT_FPS=15

FRIGATE_TIMEZONE=Asia/Bangkok

# Frigate authentication (change these!)
FRIGATE_DEFAULT_USER=admin
FRIGATE_DEFAULT_PASSWORD=SquareGuardian2026

# SquareGuardian detector settings
POLL_INTERVAL_SEC=1
TRACKED_ITEMS=person,car,motorcycle,bus,backpack,suitcase,handbag

# Snapshot burst: capture multiple snapshots and pick the sharpest one
# Higher count = better chance of sharp face, but uses more CPU.
# เพิ่มจำนวนได้ถ้าต้องการเพิ่มโอกาสจับหน้าที่คมชัด
# crop + full-frame สลับกันทุก 3 burst → เพิ่มโอกาสจับหน้าที่ขอบเฟรม
SNAPSHOT_BURST_COUNT=10
SNAPSHOT_BURST_INTERVAL_MS=500

# Alert cooldown: seconds to suppress duplicate face-id alerts per camera (0=disabled)
ALERT_COOLDOWN_SEC=300

# Storage limits (circular buffer: delete oldest when full)
MAX_STORAGE_GB=256
BUFFER_GB=10
SAVE_INTERVAL_SEC=30

# ===== CompreFace (Face Identification) =====
# CompreFace admin UI: http://localhost:8000
# สร้าง Recognition Service ใน CompreFace admin แล้วเอา API key มาใส่
COMPREFACE_DB_PASSWORD=compreface
COMPREFACE_ADMIN_KEY=admin-api-key-change-me
COMPREFACE_RECOGNITION_KEY=your-recognition-api-key-here
COMPREFACE_THRESHOLD=0.90

# ===== MQTT =====
MQTT_TOPIC_PREFIX=frigate

# ===== Legacy Face Service (optional — ใช้ docker compose --profile legacy-face up) =====
# Set to empty to disable. Only needed if NOT using CompreFace.
FACE_SERVICE_URL=
FACE_MODEL_NAME=buffalo_l
FACE_DET_SIZE=640
FACE_MATCH_THRESHOLD=0.48
FACE_SUGGEST_THRESHOLD=0.38

# ===== Notifications =====
# LINE Notify: สมัครที่ https://notify-bot.line.me/
LINE_NOTIFY_TOKEN=

# Telegram Bot: สร้าง bot ที่ @BotFather แล้วหา chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Custom Webhook (POST JSON payload เมื่อมี alert)
WEBHOOK_URL=
